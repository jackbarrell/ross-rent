PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
USE_MOCK_DATA=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Live API Keys (required when USE_MOCK_DATA=false) ───
# RentCast: property listings + comparable sales
# Sign up at https://developers.rentcast.io
RENTCAST_API_KEY=

# Mashvisor: Airbnb/STR market analytics + rental comps
# Sign up at https://www.mashvisor.com/api
MASHVISOR_API_KEY=

# FRED: Federal Reserve economic data (unemployment, home prices)
# Sign up at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# WalkScore: walkability scores by lat/lng
# Sign up at https://www.walkscore.com/professional/api.php
WALKSCORE_API_KEY=

# Census Bureau: population and demographic data
# Sign up at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
